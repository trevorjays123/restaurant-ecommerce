# Environment Variables

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/restaurant-ecommerce

# JWT Secret (generate a secure random string)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Server Configuration
PORT=5000
NODE_ENV=development

# Paystack Configuration (Get keys from https://dashboard.paystack.com)
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# Flutterwave Configuration (Get keys from https://dashboard.flutterwave.com)
FLUTTERWAVE_SECRET_KEY=flw_test_your_flutterwave_secret_key
FLUTTERWAVE_PUBLIC_KEY=flw_test_your_flutterwave_public_key

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# WhatsApp Business Configuration
WHATSAPP_NUMBER=2348012345678
WHATSAPP_BUSINESS_ID=your_whatsapp_business_id

# SMS Configuration (Termii or Africa's Talking)
SMS_API_KEY=your_sms_api_key
SMS_SENDER=YourBrand

# Email Configuration (SendGrid, Mailgun, etc.)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@yourdomain.com

# Delivery Fee Configuration
BASE_DELIVERY_FEE=500
DELIVERY_FEE_PER_KM=50
FREE_DELIVERY_THRESHOLD=10000

# Loyalty Points Configuration
POINTS_PER_Naira=1
POINTS_REDEMPTION_RATE=100
SIGNUP_BONUS_POINTS=500
BIRTHDAY_BONUS_POINTS=1000
